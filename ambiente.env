DB_HOST=bd-velho.expresslog.internal

# --- INCIDENTES DO LABORATÓRIO ---

# Incidente 1: Mude para DEBUG para resolver o problema.
LOG_LEVEL=ERROR

# Incidente 2: Manutenção (Mude para OFF para o sistema voltar)
MAINTENANCE_MODE=ON

# Incidente 2: Senha Incorreta (A senha correta exigida pela API é senha_secreta_2026)
DB_PASSWORD=senha_antiga_123

# Incidente 4: Lentidão extrema / Gargalo (Tempo de espera em milissegundos)
DB_DELAY=0
